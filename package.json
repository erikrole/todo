{
  "name": "todo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @todo/web dev",
    "build": "pnpm --filter @todo/web build && pnpm --filter @todo/mcp build",
    "db:generate": "pnpm --filter @todo/db generate",
    "db:migrate": "pnpm --filter @todo/db migrate",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
