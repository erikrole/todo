{
  "name": "todo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @todo/web dev",
    "build": "pnpm --filter @todo/web build && pnpm --filter @todo/mcp build",
    "db:generate": "pnpm --filter @todo/db generate",
    "predb:migrate": "cp packages/db/local.db packages/db/local.db.bak 2>/dev/null || true",
    "db:migrate": "dotenv -e packages/web/.env.local -- pnpm --filter @todo/db migrate",
    "db:seed": "dotenv -e packages/web/.env.local -- pnpm --filter @todo/db seed",
    "e2e": "pnpm --filter @todo/web e2e",
    "e2e:ui": "pnpm --filter @todo/web e2e:ui",
    "format": "prettier --write ."
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
